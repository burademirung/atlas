# Copy to terraform.tfvars and fill in. Do NOT commit terraform.tfvars.
# The Cloudflare token is read from the environment, not this file:
#   export TF_VAR_cloudflare_api_token=...

project            = "atlas"
environment        = "dev"
region             = "us-east-1"
vpc_cidr           = "10.10.0.0/16"
kubernetes_version = "1.31"

# Private-only by default. To use the public API endpoint, list your office/VPN
# egress CIDRs here (never 0.0.0.0/0), e.g. ["198.51.100.10/32"].
eks_public_access_cidrs = []

# ---- Cloudflare ----
cloudflare_account_id = "0123456789abcdef0123456789abcdef"
cloudflare_zone_id    = "fedcba9876543210fedcba9876543210"
app_hostname          = "dev.atlas.example.com"
origin_api_url        = "https://api-dev.atlas.internal.example.com"

# ---- Application secrets (created out-of-band; pass their ARNs) ----
# additional_secret_arns = [
#   "arn:aws:secretsmanager:us-east-1:111122223333:secret:atlas-dev/app/jwt-XXXX",
#   "arn:aws:secretsmanager:us-east-1:111122223333:secret:atlas-dev/providers/tavily-XXXX",
# ]
# additional_secret_kms_key_arns = [
#   "arn:aws:kms:us-east-1:111122223333:key/abcd1234-...",
# ]
